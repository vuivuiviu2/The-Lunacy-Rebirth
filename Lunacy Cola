local TOOL_ID = "rbxassetid://82285752606096"
local ANIM_ID = "rbxassetid://100296215597460"
local ICON_ID = "rbxassetid://73044343517626" 
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local Debris = game:GetService("Debris")

local player = game:GetService("Players").LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

_G.ColaSpeedMultiplier = _G.ColaSpeedMultiplier or 1
local BASE_SPEED = 16

-- --- HÀM TẢI ÂM THANH CUSTOM (GITHUB) ---
local function GitAud(soundlink, filename)
    local FileName = filename
    if not isfile(FileName..".mp3") then
        writefile(FileName..".mp3", game:HttpGet(soundlink))
    end
    return (getcustomasset or getsynasset)(FileName..".mp3")
end

-- Tải sẵn âm thanh lon rơi
local ROID_SOUND_ID = GitAud("https://github.com/vuivuiviu2/The-Lunacy-Rebirth/raw/refs/heads/main/roi_1.mp3", "cola_drop")

-- --- ANTI-CHEAT COLLISION ---
local function startAntiCheat(char)
    if char:FindFirstChild("CollisionClone") then char.CollisionClone:Destroy() end
    local col = char:FindFirstChild("CollisionPart") or char:FindFirstChild("Collision") or rootPart
    local colClone = col:Clone()
    colClone.CanCollide = false
    colClone.Massless = true
    colClone.CanQuery = false 
    colClone.Name = "CollisionClone"
    colClone.Parent = char
    
    task.spawn(function()
        while char.Parent do
            if rootPart.Anchored then
                colClone.Massless = true
                repeat task.wait() until not rootPart.Anchored
                task.wait(0.15)
            else
                colClone.Massless = not colClone.Massless
            end
            task.wait(0.3)
        end
    end)
end
startAntiCheat(character)

-- Vòng lặp WalkSpeed
if not _G.SpeedLoopConnected then
    _G.SpeedLoopConnected = true
    RunService.Heartbeat:Connect(function()
        if humanoid and humanoid.Parent then
            local finalSpeed = BASE_SPEED * _G.ColaSpeedMultiplier
            if finalSpeed > 32 then finalSpeed = 32 end 
            humanoid.WalkSpeed = finalSpeed
        end
    end)
end

-- --- LOGIC BLOXY COLA ---
local holdAnim = Instance.new("Animation")
holdAnim.AnimationId = ANIM_ID

local function getCola()
    local success, objects = pcall(function() return game:GetObjects(TOOL_ID) end)
    if success and objects[1] then
        local tool = objects[1]:IsA("Tool") and objects[1] or objects[1]:FindFirstChildOfClass("Tool")
        if tool then
            tool.TextureId = ICON_ID
            local raisedGrip = CFrame.new(0.5, -0.5, 0) 
            local drinkingGrip = CFrame.new(1.6, -0.5, 1.3) * CFrame.Angles(math.rad(-90), 0, 0)
            local fastTween = TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)

            tool.Grip = raisedGrip
            tool.Parent = player:FindFirstChildOfClass("Backpack")

            local currentAnimTrack = nil
            tool.Equipped:Connect(function()
                currentAnimTrack = humanoid:LoadAnimation(holdAnim)
                currentAnimTrack.Priority = Enum.AnimationPriority.Action
                currentAnimTrack:Play()
            end)
            
            tool.Unequipped:Connect(function()
                if currentAnimTrack then currentAnimTrack:Stop() end
            end)

            local isDrinking = false
            tool.Activated:Connect(function()
                if isDrinking then return end
                isDrinking = true

                TweenService:Create(tool, fastTween, {Grip = drinkingGrip}):Play()
                
                local ds = tool:FindFirstChildWhichIsA("Sound", true) or Instance.new("Sound", tool.Handle)
                ds.SoundId = "rbxassetid://10722059"
                ds.Volume = 8
                ds:Play()

                task.spawn(function()
                    _G.ColaSpeedMultiplier = _G.ColaSpeedMultiplier + 0.5
                    local pLight = Instance.new("PointLight")
                    pLight.Color = Color3.fromRGB(170, 0, 255)
                    pLight.Range = 15
                    pLight.Brightness = 3
                    pLight.Parent = rootPart
                    task.wait(15)
                    if pLight then pLight:Destroy() end
                    _G.ColaSpeedMultiplier = _G.ColaSpeedMultiplier - 0.5
                end)

                task.wait(1.5) 
                humanoid.Health = math.min(humanoid.Health + 25, humanoid.MaxHealth)
                
                local lower = TweenService:Create(tool, TweenInfo.new(0.15), {Grip = raisedGrip})
                lower:Play()
                lower.Completed:Connect(function()
                    local handle = tool:FindFirstChild("Handle")
                    if handle then
                        local dropPart = handle:Clone()
                        dropPart.Name = "FastEmptyCola"
                        dropPart.CanCollide = true
                        dropPart.CFrame = handle.CFrame
                        dropPart.CustomPhysicalProperties = PhysicalProperties.new(0.5, 0.3, 0.9, 1, 1)
                        dropPart.Parent = game.Workspace
                        
                        -- Lực ném
                        local throwDirection = (rootPart.CFrame.lookVector * 55) + Vector3.new(0, 15, 0)
                        dropPart.Velocity = throwDirection
                        dropPart.RotVelocity = Vector3.new(math.random(-70, 70), math.random(-70, 70), math.random(-70, 70))
                        
                        -- --- PHẦN MỚI: TIẾNG LON RƠI KHI CHẠM ĐẤT ---
                        local hasPlayed = false
                        dropPart.Touched:Connect(function(hit)
                            if not hasPlayed and not hit:IsDescendantOf(character) then
                                hasPlayed = true
                                local sfx = Instance.new("Sound")
                                sfx.SoundId = ROID_SOUND_ID
                                sfx.Volume = 2
                                sfx.Parent = dropPart
                                sfx:Play()
                                -- Xóa âm thanh sau khi phát xong để tối ưu
                                Debris:AddItem(sfx, 2)
                            end
                        end)
                        
                        Debris:AddItem(dropPart, 10)
                    end

                    if currentAnimTrack then currentAnimTrack:Stop() end
                    tool:Destroy()
                    isDrinking = false
                end)
            end)
        end
    end
end

getCola()
